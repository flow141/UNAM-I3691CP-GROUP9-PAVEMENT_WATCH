import sys
from PyQt5.QtWidgets import QApplication, QMainWindow, QStackedWidget
from screens.login_screen import LoginScreen
from screens.register_screen import RegisterScreen
from screens.inspector_screen import InspectorScreen
from screens.report_defect_screen import ReportDefectScreen
from screens.engineer_screen import EngineerScreen
from screens.supervisor_screen import SupervisorScreen
from screens.admin_screen import AdminScreen

class MainWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("PavementWatch")
        self.setMinimumSize(400, 600)

        self.stack = QStackedWidget()
        self.setCentralWidget(self.stack)

        self.screens = {}
        self.add_screen("login", LoginScreen(self.switch_screen))
        self.add_screen("register", RegisterScreen(self.switch_screen))
        self.add_screen("inspector", InspectorScreen(self.switch_screen))
        self.add_screen("report_defect", ReportDefectScreen(self.switch_screen))
        self.add_screen("engineer", EngineerScreen(self.switch_screen))
        self.add_screen("supervisor", SupervisorScreen(self.switch_screen))
        self.add_screen("admin", AdminScreen(self.switch_screen))

        self.switch_screen("login")

    def add_screen(self, name, widget):
        self.screens[name] = widget
        self.stack.addWidget(widget)

    def switch_screen(self, name):
        if name in self.screens:
            self.stack.setCurrentWidget(self.screens[name])

if __name__ == "__main__":
    app = QApplication(sys.argv)
    app.setStyle("Fusion")
    window = MainWindow()
    window.show()
    sys.exit(app.exec_())
# services/auth_service.py
import json
import os
import requests

SESSION_FILE = "session.json"
FIREBASE_WEB_API_KEY = "your-web-api-key-here"

def save_session(user_data):
    with open(SESSION_FILE, "w") as f:
        json.dump(user_data, f)

def clear_session():
    if os.path.exists(SESSION_FILE):
        os.remove(SESSION_FILE)

def get_current_user():
    if os.path.exists(SESSION_FILE):
        with open(SESSION_FILE, "r") as f:
            return json.load(f)
    return None

def login_user(email, password):
    url = f"https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key={FIREBASE_WEB_API_KEY}"
    response = requests.post(url, json={
        "email": email,
        "password": password,
        "returnSecureToken": True,
    })
    data = response.json()
    if "error" in data:
        raise Exception(data["error"].get("message", "Login failed"))
    uid = data["localId"]
    profile = get_user_profile(uid)
    save_session({"uid": uid, "email": email})
    return profile

def register_user(email, password, display_name, role, zone):
    from services.firebase_config import get_auth, get_db
    firebase_auth = get_auth()
    db = get_db()
    user = firebase_auth.create_user(
        email=email, password=password, display_name=display_name
    )
    profile = {
        "uid": user.uid,
        "displayName": display_name,
        "email": email,
        "role": role,
        "zone": zone,
    }
    db.collection("users").document(user.uid).set(profile)
    save_session({"uid": user.uid, "email": email})
    return profile

def logout_user():
    clear_session()

def reset_password(email):
    url = f"https://identitytoolkit.googleapis.com/v1/accounts:sendOobCode?key={FIREBASE_WEB_API_KEY}"
    response = requests.post(url, json={
        "requestType": "PASSWORD_RESET",
        "email": email,
    })
    data = response.json()
    if "error" in data:
        raise Exception(data["error"].get("message", "Reset failed"))

def get_user_profile(uid):
    from services.firebase_config import get_db
    db = get_db()
    doc = db.collection("users").document(uid).get()
    return doc.to_dict() if doc.exists else None

