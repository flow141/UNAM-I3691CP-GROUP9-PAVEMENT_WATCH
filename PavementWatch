        type_label.setStyleSheet("color: gray; font-size: 13px;")
        layout.addWidget(type_label)

        self.defect_type = QComboBox()
        self.defect_type.addItems(["Pothole", "Crack", "Edge Break"])
        self.defect_type.setFixedHeight(42)
        layout.addWidget(self.defect_type)

        # Severity
        sev_label = QLabel("Severity")
        sev_label.setStyleSheet("color: gray; font-size: 13px;")
        layout.addWidget(sev_label)

        self.severity = QComboBox()
        self.severity.addItems(["Low", "Medium", "High"])
        self.severity.setFixedHeight(42)
        layout.addWidget(self.severity)

        # Photo
        photo_btn = QPushButton("📷  Select Before Photo")
        photo_btn.setFixedHeight(46)
        photo_btn.setStyleSheet("background-color: #1565C0; color: white; font-size: 14px; border-radius: 6px;")
        photo_btn.clicked.connect(self.pick_photo)
        layout.addWidget(photo_btn)

        self.photo_label = QLabel("No photo selected")
        self.photo_label.setStyleSheet("color: gray; font-size: 13px;")
        layout.addWidget(self.photo_label)

        # Submit
        submit_btn = QPushButton("Submit Report")
        submit_btn.setFixedHeight(50)
        submit_btn.setStyleSheet("background-color: #E53935; color: white; font-size: 15px; border-radius: 6px;")
        submit_btn.clicked.connect(self.handle_submit)
        layout.addWidget(submit_btn)

        # Back
        back_btn = QPushButton("← Back")
        back_btn.setStyleSheet("color: gray; border: none; background: none;")
        back_btn.clicked.connect(lambda: self.switch_screen("inspector"))
        layout.addWidget(back_btn)

        self.setLayout(layout)

    def pick_photo(self):
        file_path, _ = QFileDialog.getOpenFileName(
            self, "Select Photo", "", "Images (*.jpg *.jpeg *.png)"
        )
        if file_path:
            self.photo_path = file_path
            self.photo_label.setText(f"✅ {os.path.basename(file_path)}")

    def handle_submit(self):
        user = get_current_user()
        if not user:
            QMessageBox.warning(self, "Error", "You are not logged in.")
            return
        if not self.photo_path:
            QMessageBox.warning(self, "No photo", "Please select a before photo.")
            return
        try:
            dest = f"defects/{user['uid']}_{int(datetime.utcnow().timestamp())}.jpg"
            photo_url = upload_photo(self.photo_path, dest)
            report_defect(
                reporter_id=user["uid"],
                lat=0.0,
                lng=0.0,
                defect_type=self.defect_type.currentText(),
                severity=self.severity.currentText(),
                photo_before_url=photo_url,
            )
            QMessageBox.information(self, "✅ Submitted", "Defect reported successfully!")
            self.photo_path = None
            self.photo_label.setText("No photo selected")
        except Exception as e:
            QMessageBox.critical(self, "Error", str(e))
