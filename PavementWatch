        self.password.setPlaceholderText("Password (min 6 characters)")
        self.password.setEchoMode(QLineEdit.Password)
        self.password.setFixedHeight(42)
        layout.addWidget(self.password)

        self.zone = QLineEdit()
        self.zone.setPlaceholderText("Geographic zone (e.g. North District)")
        self.zone.setFixedHeight(42)
        layout.addWidget(self.zone)

        role_label = QLabel("Role")
        role_label.setStyleSheet("color: gray; font-size: 13px;")
        layout.addWidget(role_label)

        self.role = QComboBox()
        self.role.addItems(["Inspector", "Engineer", "Supervisor", "Admin"])
        self.role.setFixedHeight(42)
        layout.addWidget(self.role)

        reg_btn = QPushButton("Register")
        reg_btn.setFixedHeight(46)
        reg_btn.setStyleSheet("background-color: #E53935; color: white; font-size: 15px; border-radius: 6px;")
        reg_btn.clicked.connect(self.handle_register)
        layout.addWidget(reg_btn)

        back_btn = QPushButton("Already have an account? Sign in")
        back_btn.setStyleSheet("color: #E53935; border: none; background: none;")
        back_btn.clicked.connect(lambda: self.switch_screen("login"))
        layout.addWidget(back_btn)

        self.setLayout(layout)

    def handle_register(self):
        from services.auth_service import register_user
        name = self.name.text().strip()
        email = self.email.text().strip()
        password = self.password.text()
        zone = self.zone.text().strip()
        role = self.role.currentText()

        if not all([name, email, password, zone]):
            QMessageBox.warning(self, "Missing fields", "Please fill in all fields.")
            return
        if len(password) < 6:
            QMessageBox.warning(self, "Weak password", "Password must be at least 6 characters.")
            return
        try:
            register_user(email, password, name, role, zone)
            role_map = {
                "Inspector": "inspector",
                "Engineer": "engineer",
                "Supervisor": "supervisor",
                "Admin": "admin",
            }
            self.switch_screen(role_map.get(role, "login"))
        except Exception as e:
            QMessageBox.critical(self, "Registration failed", str(e))
