from PyQt5.QtWidgets import (
    QWidget, QVBoxLayout, QLabel, QLineEdit, QPushButton, QMessageBox
)
from PyQt5.QtCore import Qt

class LoginScreen(QWidget):
    def __init__(self, switch_screen):
        super().__init__()
        self.switch_screen = switch_screen
        layout = QVBoxLayout()
        layout.setSpacing(12)
        layout.setContentsMargins(40, 40, 40, 40)

        title = QLabel("🛣️ PavementWatch")
        title.setAlignment(Qt.AlignCenter)
        title.setStyleSheet("font-size: 26px; font-weight: bold; color: #E53935;")
        layout.addWidget(title)

        subtitle = QLabel("Municipal Road Inspection")
        subtitle.setAlignment(Qt.AlignCenter)
        subtitle.setStyleSheet("font-size: 13px; color: gray;")
        layout.addWidget(subtitle)

        self.email = QLineEdit()
        self.email.setPlaceholderText("Corporate email")
        self.email.setFixedHeight(42)
        layout.addWidget(self.email)

        self.password = QLineEdit()
        self.password.setPlaceholderText("Password")
        self.password.setEchoMode(QLineEdit.Password)
        self.password.setFixedHeight(42)
        layout.addWidget(self.password)

        login_btn = QPushButton("Sign In")
        login_btn.setFixedHeight(46)
        login_btn.setStyleSheet("background-color: #E53935; color: white; font-size: 15px; border-radius: 6px;")
        login_btn.clicked.connect(self.handle_login)
        layout.addWidget(login_btn)

        forgot_btn = QPushButton("Forgot password?")
        forgot_btn.setStyleSheet("color: #E53935; border: none; background: none;")
        forgot_btn.clicked.connect(self.handle_reset)
        layout.addWidget(forgot_btn)

        register_btn = QPushButton("Don't have an account? Register")
        register_btn.setStyleSheet("color: #E53935; border: none; background: none;")
        register_btn.clicked.connect(lambda: self.switch_screen("register"))
        layout.addWidget(register_btn)

        self.setLayout(layout)

    def handle_login(self):
        from services.auth_service import login_user
        email = self.email.text().strip()
        password = self.password.text()
        if not email or not password:
            QMessageBox.warning(self, "Error", "Please enter your email and password.")
            return
        try:
            profile = login_user(email, password)
            role_map = {
                "Inspector": "inspector",
                "Engineer": "engineer",
                "Supervisor": "supervisor",
                "Admin": "admin",
            }
            self.switch_screen(role_map.get(profile["role"], "login"))
        except Exception as e:
            QMessageBox.critical(self, "Login failed", str(e))

    def handle_reset(self):
        from services.auth_service import reset_password
        email = self.email.text().strip()
        if not email:
            QMessageBox.warning(self, "Reset", "Enter your email above first.")
            return
        try:
            reset_password(email)
            QMessageBox.information(self, "Email sent", "Check your inbox for a reset link.")
        except Exception as e:
            QMessageBox.critical(self, "Error", str(e))

