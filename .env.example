# Geoapify allows one service per API key — create two keys at https://myprojects.geoapify.com/

# Key 1: restrict to "Map Tiles"
EXPO_PUBLIC_GEOAPIFY_MAPS_API_KEY=

# Key 2: restrict to "Reverse geocoding API"
EXPO_PUBLIC_GEOAPIFY_GEOCODING_API_KEY=

# Firebase — find these in the Firebase Console under Project Settings > Your apps
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
